# App
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
JWT_SECRET=replace_with_a_secure_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_a_secure_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=14d
JWT_REFRESH_COOKIE_MAX_AGE_MS=1209600000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
ADMIN_BOOTSTRAP_KEY=replace_with_one_time_admin_bootstrap_key

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/golf_charity
MONGODB_DB_NAME=golf_charity
MONGODB_RETRY_WRITES=true
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=0
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=15000
MONGODB_SOCKET_TIMEOUT_MS=45000
MONGODB_DNS_SERVERS=

# MySQL
MYSQL_URL=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=golf_charity
MYSQL_CONNECTION_LIMIT=10
MYSQL_AUTO_INIT_SCHEMA=true
MYSQL_SSL_ENABLED=false
MYSQL_SSL_REJECT_UNAUTHORIZED=true
SUBSCRIPTION_ENFORCEMENT_ENABLED=true

# Email Notifications
EMAIL_ENABLED=false
EMAIL_FROM=no-reply@golf-charity.local
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=your_smtp_username
EMAIL_SMTP_PASS=your_smtp_password
