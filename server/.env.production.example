# App
NODE_ENV=production
PORT=5000
CLIENT_URL=https://your-frontend-domain.com
TRUST_PROXY=true
JSON_BODY_LIMIT=1mb

# Auth
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=14d
JWT_REFRESH_COOKIE_MAX_AGE_MS=1209600000
COOKIE_SECURE=true
COOKIE_SAME_SITE=none
ADMIN_BOOTSTRAP_KEY=replace_with_one_time_admin_bootstrap_key

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/golf_charity
MONGODB_DB_NAME=golf_charity
MONGODB_RETRY_WRITES=true
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=0
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=15000
MONGODB_SOCKET_TIMEOUT_MS=45000

# MySQL
MYSQL_URL=
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=golf_charity
MYSQL_CONNECTION_LIMIT=10
MYSQL_AUTO_INIT_SCHEMA=false
MYSQL_SSL_ENABLED=true
MYSQL_SSL_REJECT_UNAUTHORIZED=true
SUBSCRIPTION_ENFORCEMENT_ENABLED=true

# Email Notifications
EMAIL_ENABLED=true
EMAIL_FROM=no-reply@your-domain.com
EMAIL_SMTP_HOST=smtp.your-provider.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=your_smtp_user
EMAIL_SMTP_PASS=your_smtp_password
